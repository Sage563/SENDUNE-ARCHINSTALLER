#!/bin/bash
# 'flip' - Sendune's package manager wrapper

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m'

show_help() {
    echo -e "${BLUE}SENDUNE flip${NC} - Package management made easy"
    echo "Usage: flip [command] [package_name]"
    echo ""
    echo "Commands:"
    echo "  install <pkg>   Install package(s)"
    echo "  yeet <pkg>      Remove package(s) and unused dependencies"
    echo "  update          Update system"
    echo "  search <query>  Search for a package"
    echo "  info <pkg>      Show package information"
    echo "  list            List all installed packages"
    echo "  autoremove      Remove orphaned packages"
    echo "  clean           Clean package cache and orphans"
    echo "  help            Show this help message"
    echo ""
}

if [ -z "$1" ]; then
    show_help
    exit 1
fi

case "$1" in
    install|get)
        shift
        if [ -z "$1" ]; then
            echo -e "${RED}Error:${NC} What should I install?"
            exit 1
        fi
        if command -v yay >/dev/null 2>&1; then
            yay -S "$@"
        else
            sudo pacman -S "$@"
        fi
        ;;
    yeet|remove|delete)
        shift
        if [ -z "$1" ]; then
            echo -e "${RED}Error:${NC} What should I yeet?"
            exit 1
        fi
        sudo pacman -Rns "$@"
        ;;
    update|up|sync)
        if command -v yay >/dev/null 2>&1; then
            yay -Syu
        else
            sudo pacman -Syu
        fi
        ;;
    search|find)
        shift
        if command -v yay >/dev/null 2>&1; then
            yay -Ss "$@"
        else
            pacman -Ss "$@"
        fi
        ;;
    clean)
        orphans="$(pacman -Qtdq 2>/dev/null || true)"
        if [ -n "$orphans" ]; then
            sudo pacman -Rns $orphans
        fi
        sudo pacman -Sc
        ;;
    info)
        shift
        if [ -z "$1" ]; then
            echo -e "${RED}Error:${NC} Which package?"
            exit 1
        fi
        if command -v yay >/dev/null 2>&1; then
            yay -Si "$@"
        else
            pacman -Si "$@"
        fi
        ;;
    list)
        pacman -Q
        ;;
    autoremove)
        orphans="$(pacman -Qtdq 2>/dev/null || true)"
        if [ -n "$orphans" ]; then
            sudo pacman -Rns $orphans
        else
            echo -e "${GREEN}Nothing to autoremove.${NC}"
        fi
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command:${NC} $1"
        show_help
        exit 1
        ;;
esac
